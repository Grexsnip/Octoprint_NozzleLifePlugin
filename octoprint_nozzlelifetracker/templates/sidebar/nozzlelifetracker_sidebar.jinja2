<h4>Phase 1 Status</h4>
<div class="nlt-dashboard" data-bind="visible: activeNozzle">
  <strong data-bind="text: 'Active ' + activeToolId() + ' Nozzle'"></strong>
  <div>
    <span data-bind="text: activeNozzle() ? activeNozzle().name : ''"></span>
    <span data-bind="text: activeNozzle() ? '(' + activeNozzle().material + ' ' + activeNozzle().size_mm + 'mm)' : ''"></span>
  </div>
  <div data-bind="visible: activeNozzle">
    <span data-bind="text: activeNozzle() ? activeNozzle().accumulated_hours + 'h' : ''"></span>
    <span data-bind="text: activeNozzle() ? (' / ' + Math.round((activeNozzle().effective_life_seconds || 0) / 3600.0 * 100) / 100 + 'h') : ''"></span>
    <span class="nlt-badge nlt-badge-overdue" data-bind="visible: activeNozzle() && activeNozzle().is_overdue">⚠ OVERDUE</span>
  </div>
</div>
<div class="muted" data-bind="text: errorText, visible: errorText"></div>
<div class="muted" data-bind="visible: lastGeneratedAt">
  Last update: <span data-bind="text: lastGeneratedAt"></span>
</div>

<div data-bind="visible: !hasTools()">No tool data available.</div>
<div class="nlt-sidebar-tools" data-bind="visible: hasTools(), foreach: tools">
  <div class="nlt-tool-card" data-bind="css: { 'nlt-overdue': is_overdue }">
    <div class="nlt-tool-card-header">
      <strong data-bind="text: 'Tool ' + tool_id"></strong>
      <span class="nlt-badge nlt-badge-overdue" data-bind="visible: is_overdue">⚠ OVERDUE</span>
    </div>
    <div class="nlt-tool-line">
      <span class="nlt-tool-label">Profile</span>
      <span class="nlt-tool-value nlt-truncate" data-bind="text: profile_name"></span>
    </div>
    <div class="nlt-tool-line">
      <span class="nlt-tool-label">Nozzle</span>
      <span class="nlt-tool-value nlt-truncate" data-bind="text: $root.nozzleLabel($root.nozzles().find(function (n) { return n.id === selected_nozzle_id(); })) || ''"></span>
    </div>
    <div class="nlt-tool-line">
      <span class="nlt-tool-label">Usage</span>
      <span class="nlt-tool-value" data-bind="text: accumulated_hours + 'h / ' + interval_hours + 'h'"></span>
    </div>
    <div class="nlt-tool-line">
      <span class="nlt-tool-label">Status</span>
      <span class="nlt-tool-value" data-bind="text: is_overdue ? 'Overdue' : 'OK'"></span>
    </div>
    <div class="nlt-tool-control">
      <label class="nlt-tool-label">Nozzle</label>
      <select class="input-block-level"
              data-bind="options: $root.nozzleOptionsForTool($data), optionsText: $root.nozzleLabel, optionsValue: 'id', value: selected_nozzle_id, event: { change: $root.assignNozzle }"></select>
    </div>
    <div class="nlt-tool-actions">
      <button class="btn btn-mini" data-bind="click: $root.resetTool">Reset</button>
    </div>
  </div>
</div>